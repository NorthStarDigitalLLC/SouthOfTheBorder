<style>
  :root{
    --hhx-bg:#07060a;
    --hhx-border: rgba(255,255,255,.14);
    --hhx-text: rgba(255,255,255,.92);
    --hhx-muted: rgba(255,255,255,.70);
    --hhx-ember:#ff5b3d;
    --hhx-ember2:#ffb04b;
    --hhx-radius: 24px;
    --hhx-radius2: 18px;
    --hhx-shadow: 0 22px 70px rgba(0,0,0,.55);
    --hhx-shadow2: 0 14px 40px rgba(0,0,0,.42);
  }

  .hhx-home{
    position: relative;
    color: var(--hhx-text);
    background:
      radial-gradient(1400px 800px at 20% -10%, rgba(255,91,61,.14), transparent 55%),
      radial-gradient(1200px 700px at 90% 0%, rgba(255,176,75,.10), transparent 55%),
      radial-gradient(1000px 700px at 50% 90%, rgba(255,255,255,.06), transparent 60%),
      var(--hhx-bg);
    overflow: hidden;
  }

  .hhx-backdrop{ position:absolute; inset:0; pointer-events:none; }
  .hhx-smoke{
    position:absolute; inset:-20%;
    background:
      radial-gradient(700px 420px at 20% 25%, rgba(255,255,255,.06), transparent 60%),
      radial-gradient(700px 420px at 70% 35%, rgba(255,255,255,.04), transparent 62%),
      radial-gradient(900px 540px at 50% 80%, rgba(255,91,61,.06), transparent 70%);
    filter: blur(16px);
    transform: rotate(-6deg);
    opacity: .9;
  }
  .hhx-glow{
    position:absolute; inset:-10%;
    background: conic-gradient(from 120deg, rgba(255,91,61,.10), rgba(255,176,75,.08), rgba(255,255,255,.06), rgba(255,91,61,.10));
    filter: blur(40px);
    opacity: .55;
  }

  .hhx-wrap{
    max-width: 1140px;
    margin: 0 auto;
    padding: 34px 16px 54px;
    position: relative;
    z-index: 1;
    font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
  }

  /* HERO */
  .hhx-hero{
    display:grid;
    grid-template-columns: 1.3fr .7fr;
    gap: 16px;
    align-items: stretch;
  }
  @media (max-width: 900px){ .hhx-hero{ grid-template-columns: 1fr; } }

  .hhx-heroCard{
    background: linear-gradient(to bottom, rgba(255,255,255,.08), rgba(255,255,255,.05));
    border: 1px solid var(--hhx-border);
    border-radius: var(--hhx-radius);
    box-shadow: var(--hhx-shadow);
    padding: 22px 20px;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    position: relative;
    overflow:hidden;
  }
  .hhx-heroCard:before{
    content:"";
    position:absolute; inset:0;
    background:
      radial-gradient(900px 260px at 15% 0%, rgba(255,91,61,.14), transparent 62%),
      radial-gradient(900px 260px at 85% 10%, rgba(255,176,75,.10), transparent 62%);
    pointer-events:none;
  }
  .hhx-heroCard > *{ position:relative; z-index:1; }

  .hhx-kicker{
    display:inline-block;
    padding: 7px 12px;
    border-radius: 999px;
    border: 1px solid rgba(255,255,255,.18);
    background: rgba(0,0,0,.22);
    font-weight: 750;
    color: var(--hhx-muted);
    font-size: 13px;
    letter-spacing: .02em;
  }

  .hhx-h1{
    margin: 12px 0 6px;
    font-size: clamp(28px, 4vw, 44px);
    letter-spacing: -0.04em;
    line-height: 1.02;
    font-weight: 950;
  }

  .hhx-sub{
    margin: 0 0 14px;
    color: var(--hhx-muted);
    font-weight: 700;
    font-size: clamp(14px, 1.6vw, 16px);
    line-height: 1.35;
  }

  .hhx-ctaRow{
    display:flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 12px 0 12px;
  }

  .hhx-btn{
    text-decoration:none;
    color: var(--hhx-text);
    border: 1px solid rgba(255,255,255,.16);
    background: rgba(0,0,0,.26);
    padding: 11px 14px;
    border-radius: 999px;
    font-weight: 850;
    font-size: 14px;
    transition: transform .14s ease, box-shadow .14s ease, background .14s ease;
    box-shadow: 0 14px 34px rgba(0,0,0,.35);
  }
  .hhx-btn:hover{ transform: translateY(-1px); box-shadow: 0 18px 46px rgba(0,0,0,.45); }
  .hhx-btn--primary{
    border-color: transparent;
    background: linear-gradient(135deg, var(--hhx-ember), var(--hhx-ember2));
    color: #1a0d0b;
    box-shadow: 0 18px 56px rgba(255,91,61,.20);
  }

  .hhx-quickFacts{
    display:flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 10px;
  }
  .hhx-pill{
    display:inline-flex;
    align-items:center;
    gap: 10px;
    padding: 9px 12px;
    border-radius: 999px;
    border: 1px solid rgba(255,255,255,.14);
    background: rgba(255,255,255,.06);
    font-weight: 800;
    color: rgba(255,255,255,.82);
    font-size: 13px;
  }
  .hhx-dot{ width:9px; height:9px; border-radius: 99px; background: var(--hhx-ember); box-shadow: 0 0 0 4px rgba(255,91,61,.18); }
  .hhx-dot2{ background: var(--hhx-ember2); box-shadow: 0 0 0 4px rgba(255,176,75,.16); }
  .hhx-dot3{ background: rgba(255,255,255,.72); box-shadow: 0 0 0 4px rgba(255,255,255,.10); }

  /* SIGNATURE SEAL (CIRCLE) */
  .hhx-sigil{
    position: relative;
    width: 240px;
    height: 240px;
    border-radius: 50%;
    display:grid;
    place-items:center;
    border: 1px solid rgba(255,255,255,.18);
    background:
      radial-gradient(circle at 30% 20%, rgba(255,176,75,.12), transparent 55%),
      radial-gradient(circle at 70% 80%, rgba(255,91,61,.14), transparent 55%),
      rgba(0,0,0,.34);
    box-shadow:
      0 30px 80px rgba(0,0,0,.62),
      inset 0 0 0 1px rgba(255,255,255,.08);
    overflow:hidden;
  }
  .hhx-sigil::before{
    content:"";
    position:absolute;
    inset:-40%;
    background: conic-gradient(
      from 0deg,
      rgba(255,91,61,.16),
      rgba(255,176,75,.14),
      rgba(255,255,255,.06),
      rgba(255,91,61,.16)
    );
    filter: blur(42px);
    opacity:.6;
    animation: hhxSealSpin 18s linear infinite;
  }
  @keyframes hhxSealSpin{ to{ transform: rotate(360deg); } }

  .hhx-sigilRing{
    position:absolute;
    inset: 20px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,.16);
    box-shadow:
      inset 0 0 28px rgba(255,255,255,.06),
      0 0 40px rgba(255,91,61,.18);
    z-index: 1;
  }

  .hhx-sigilCore{
    position:absolute;
    width: 140px;
    height: 140px;
    border-radius: 50%;
    background:
      radial-gradient(circle at 30% 20%, rgba(255,255,255,.10), transparent 60%),
      rgba(0,0,0,.28);
    border: 1px solid rgba(255,255,255,.12);
    box-shadow: inset 0 0 40px rgba(0,0,0,.55);
    z-index: 2;
  }

  .hhx-sigilLogo{
    position: relative;
    z-index: 3;
    width: 96px;
    height: 96px;
    border-radius: 50%;
    object-fit: cover;
    background: rgba(0,0,0,.35);
    border: 2px solid rgba(255,255,255,.22);
    box-shadow:
      0 20px 48px rgba(0,0,0,.6),
      inset 0 0 0 1px rgba(255,255,255,.12);
  }

  .hhx-sigilText{
    position:absolute;
    bottom: 14px;
    z-index: 4;
    font-weight: 900;
    letter-spacing: .30em;
    font-size: 11px;
    color: rgba(255,255,255,.74);
  }

  @media (max-width: 900px){
    .hhx-sigil{ width: 200px; height: 200px; margin: 0 auto; }
    .hhx-sigilCore{ width: 118px; height: 118px; }
    .hhx-sigilLogo{ width: 84px; height: 84px; }
  }

  /* NAV GRID */
  .hhx-navGrid{
    display:grid;
    grid-template-columns: repeat(4, minmax(0,1fr));
    gap: 12px;
    margin: 14px 0;
  }
  @media (max-width: 900px){ .hhx-navGrid{ grid-template-columns: repeat(2, minmax(0,1fr)); } }
  @media (max-width: 520px){ .hhx-navGrid{ grid-template-columns: 1fr; } }

  .hhx-navCard{
    display:block;
    text-decoration:none;
    color: var(--hhx-text);
    border: 1px solid rgba(255,255,255,.14);
    background: rgba(255,255,255,.06);
    border-radius: var(--hhx-radius2);
    padding: 14px;
    box-shadow: 0 14px 40px rgba(0,0,0,.35);
    transition: transform .14s ease, background .14s ease, box-shadow .14s ease;
  }
  .hhx-navCard:hover{ transform: translateY(-2px); background: rgba(255,255,255,.08); box-shadow: 0 18px 56px rgba(0,0,0,.44); }

  .hhx-navIcon{ font-size: 22px; opacity: .95; }
  .hhx-navTitle{ margin-top: 8px; font-weight: 950; letter-spacing: -0.02em; font-size: 16px; }
  .hhx-navDesc{ margin-top: 6px; color: var(--hhx-muted); font-weight: 700; font-size: 13px; line-height: 1.35; }

  /* SPLIT */
  .hhx-split{
    display:grid;
    grid-template-columns: 1.2fr .8fr;
    gap: 12px;
    margin-top: 12px;
  }
  @media (max-width: 900px){ .hhx-split{ grid-template-columns: 1fr; } }

  .hhx-panel{
    border-radius: var(--hhx-radius);
    border: 1px solid rgba(255,255,255,.14);
    background: rgba(255,255,255,.06);
    box-shadow: var(--hhx-shadow2);
    padding: 18px;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .hhx-h2{
    margin: 0 0 8px;
    font-weight: 950;
    letter-spacing: -0.03em;
    font-size: clamp(18px, 2.5vw, 22px);
  }
  .hhx-p{
    margin: 0;
    color: var(--hhx-muted);
    font-weight: 700;
    font-size: 14px;
    line-height: 1.45;
  }

  .hhx-featureRow{
    margin-top: 14px;
    display:grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }
  @media (max-width: 560px){ .hhx-featureRow{ grid-template-columns: 1fr; } }

  .hhx-feature{
    border-radius: 18px;
    border: 1px solid rgba(255,255,255,.14);
    background: rgba(0,0,0,.20);
    padding: 12px;
  }
  .hhx-featureTop{ display:flex; gap:8px; flex-wrap:wrap; margin-bottom: 8px; }
  .hhx-chip{
    font-size: 12px;
    font-weight: 900;
    letter-spacing: .08em;
    text-transform: uppercase;
    padding: 6px 10px;
    border-radius: 999px;
    border: 1px solid rgba(255,255,255,.14);
    background: rgba(255,255,255,.06);
    color: rgba(255,255,255,.80);
  }
  .hhx-featureText{ color: rgba(255,255,255,.72); font-weight: 700; font-size: 13px; line-height: 1.4; }

  .hhx-panel--info .hhx-infoTop{
    display:flex;
    align-items:flex-start;
    justify-content: space-between;
    gap: 10px;
